rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user data: only the owning authenticated user may read/write their own documents.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /discoveries/{discoveryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // friends subcollection lives under each user's doc.
      // Owner can read/write their own list.
      // The *other* party (friendId) can also write — needed so that:
      //   • accept: acceptor can write sender into sender's friends list
      //   • unfriend: either side can remove the other
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == friendId);

        match /messages/{messageId} {
          // Per-user fallback messages (owner-only access).
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Top-level progress collection: only the owning user may read/write
    match /progress/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Top-level discoveries collection: only the owning user may read/write
    match /discoveries/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow anyone to check username availability (needed during registration
    // before the user is authenticated). Write access is still restricted.
    match /usernames/{username} {
      allow read: if true;

      // Create rule: require the provided uid to match the authenticated user.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email is string
                    && request.resource.data.email != '';

      // Allow the owning user to delete their own username mapping when they change
      // their username.
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

      // Do not allow arbitrary updates of username docs (prevents renaming by update)
      allow update: if false;
    }

    // Friend requests: sender may create; sender or recipient may read/delete.
    // Recipient may update with acceptedAt (kept for backward compatibility).
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid != ''
                    && request.resource.data.fromUid != request.resource.data.toUid;

      allow read, delete: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.toUid == request.auth.uid;

      // Allow recipient to update the request to add acceptedAt timestamp
      allow update: if request.auth != null
                     && resource.data.toUid == request.auth.uid
                     && request.resource.data.acceptedAt is timestamp;
    }

    // Chats: only participants may create/read/write.
    match /chats/{chatId} {
      // Create a chat only when the request includes a participants array containing the requester
      allow create: if request.auth != null
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 2
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants[0] != request.resource.data.participants[1];

      // Read/update/delete only allowed for existing participants
      allow read, update, delete: if request.auth != null
                                   && request.auth.uid in resource.data.participants;

      // Messages subcollection: only participants may create/read messages
      match /messages/{messageId} {
        allow create: if request.auth != null
                      && request.resource.data.fromUid == request.auth.uid
                      && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        allow read: if request.auth != null
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        allow update, delete: if false;
      }
    }

    // Volcano experiment multiplayer games
    match /volcanoGames/{gameId} {
      // Anyone authenticated can create a game (as player1)
      allow create: if request.auth != null
                    && request.resource.data.player1Uid == request.auth.uid;

      // Only participants can read the game
      allow read: if request.auth != null
                  && (resource.data.player1Uid == request.auth.uid 
                      || resource.data.player2Uid == request.auth.uid
                      || resource.data.player2Uid == null);

      // Only participants can update (for joining and gameplay)
      allow update: if request.auth != null
                    && (resource.data.player1Uid == request.auth.uid 
                        || resource.data.player2Uid == request.auth.uid
                        || (resource.data.player2Uid == null && request.resource.data.player2Uid == request.auth.uid));

      // Only player1 can delete the game
      allow delete: if request.auth != null
                    && resource.data.player1Uid == request.auth.uid;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user data: only the owning authenticated user may read/write their own documents.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /discoveries/{discoveryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // friends subcollection lives under each user's doc.
      // Owner can read/write their own list.
      // The *other* party (friendId) can also write — needed so that:
      //   • accept: acceptor can write sender into sender's friends list
      //   • unfriend: either side can remove the other
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == friendId);

        match /messages/{messageId} {
          // Per-user fallback messages (owner-only access).
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Blocked users subcollection
      // Owner can read/write their own blocked list to prevent interactions
      match /blocked/{blockedUid} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Top-level progress collection: only the owning user may read/write
    match /progress/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Top-level discoveries collection: only the owning user may read/write
    match /discoveries/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Top-level notebooks collection: only the owning user may read/write
    match /notebooks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests: sender may create; sender or recipient may read/delete.
    // Recipient may update with acceptedAt (kept for backward compatibility).
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid != ''
                    && request.resource.data.fromUid != request.resource.data.toUid;

      allow read, delete: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.toUid == request.auth.uid;

      // Allow recipient to update the request to add acceptedAt timestamp
      allow update: if request.auth != null
                     && resource.data.toUid == request.auth.uid
                     && request.resource.data.acceptedAt is timestamp;
    }

    // Chats: only participants may create/read/write.
    match /chats/{chatId} {
      // Create a chat only when the request includes a participants array containing the requester
      allow create: if request.auth != null
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 2
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants[0] != request.resource.data.participants[1];

      // Read/update/delete only allowed for existing participants
      allow read, update, delete: if request.auth != null
                                   && request.auth.uid in resource.data.participants;

      // Messages subcollection: only participants may create/read messages
      match /messages/{messageId} {
        allow create: if request.auth != null
                      && request.resource.data.fromUid == request.auth.uid
                      && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        allow read: if request.auth != null
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        allow update: if request.auth != null
                       && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow delete: if false;
      }
    }

    // Volcano experiment multiplayer games
    match /volcanoGames/{gameId} {
      allow create: if request.auth != null
                    && request.resource.data.player1.uid == request.auth.uid;

      allow read: if request.auth != null
                  && (resource.data.player1.uid == request.auth.uid 
                      || (resource.data.player2 != null && resource.data.player2.uid == request.auth.uid)
                      || resource.data.player2 == null);

      allow update: if request.auth != null
                    && (resource.data.player1.uid == request.auth.uid 
                        || (resource.data.player2 != null && resource.data.player2.uid == request.auth.uid)
                        || (resource.data.player2 == null && request.resource.data.player2.uid == request.auth.uid));

      allow delete: if request.auth != null
                    && resource.data.player1.uid == request.auth.uid;
    }

    // Group Chats: only members may read/write
    match /groupChats/{groupId} {
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.memberUids is list
                    && request.resource.data.memberUids.size() >= 2
                    && request.auth.uid in request.resource.data.memberUids;

      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;

      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids;

      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow create: if request.auth != null
                      && request.resource.data.fromUid == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/groupChats/$(groupId)).data.memberUids;

        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groupChats/$(groupId)).data.memberUids;

        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/groupChats/$(groupId)).data.memberUids;
        allow delete: if false;
      }
    }

    // Elephant Toothpaste (foam-race) multiplayer games
    match /foamGames/{gameId} {
      allow create: if request.auth != null && request.resource.data.player1 == request.auth.uid;
      allow read: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || resource.data.player2 == null);
      allow update: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || (resource.data.player2 == null && request.resource.data.player2 == request.auth.uid));
      allow delete: if request.auth != null && resource.data.player1 == request.auth.uid;
    }

    // Balloon Race multiplayer games
    match /balloonGames/{gameId} {
      allow create: if request.auth != null && request.resource.data.player1 == request.auth.uid;
      allow read: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || resource.data.player2 == null);
      allow update: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || (resource.data.player2 == null && request.resource.data.player2 == request.auth.uid));
      allow delete: if request.auth != null && resource.data.player1 == request.auth.uid;
    }

    // pH Challenge multiplayer games
    match /phGames/{gameId} {
      allow create: if request.auth != null && request.resource.data.player1 == request.auth.uid;
      allow read: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || resource.data.player2 == null);
      allow update: if request.auth != null && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid || (resource.data.player2 == null && request.resource.data.player2 == request.auth.uid));
      allow delete: if request.auth != null && resource.data.player1 == request.auth.uid;
    }

    // Notifications: sender creates for the recipient; recipient can read/delete.
    match /notifications/{notificationId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid != '';

      allow read, delete: if request.auth != null
                          && resource.data.toUid == request.auth.uid;
    }

    // Reports: any authenticated user can create a report.
    match /reports/{reportId} {
      allow create: if request.auth != null;
      // Restrict read access to admins (optional, but good for privacy)
      allow read: if false; 
    }

    // Reviews/Ratings: One review per user (document ID is userId)
    match /reviews/{userId} {
      // Only authenticated users with verified email can create their own review
      allow create: if request.auth != null
                    && request.auth.token.email_verified == true
                    && userId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 4
                    && request.resource.data.rating is int;

      // Any authenticated user can read reviews
      allow read: if request.auth != null;

      // Only the author can update their review
      allow update: if request.auth != null
                    && request.auth.token.email_verified == true
                    && userId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 4;

      // Only the author can delete their review
      allow delete: if request.auth != null && userId == request.auth.uid;
    }

    // Game Ratings: One rating per user per game
    match /gameRatings/{gameId}/ratings/{userId} {
      // Anyone can read game ratings so aggregate stars can be shown publicly.
      allow read: if true;

      // Only authenticated users with verified email can create their own rating.
      allow create: if request.auth != null
                    && request.auth.token.email_verified == true
                    && userId == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                      'gameId',
                      'rating',
                      'createdAt',
                      'updatedAt'
                    ])
                    && request.resource.data.gameId == gameId
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.rating is int
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.updatedAt is timestamp;

      // Only the author can update their rating.
      allow update: if request.auth != null
                    && request.auth.token.email_verified == true
                    && userId == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                      'gameId',
                      'rating',
                      'createdAt',
                      'updatedAt'
                    ])
                    && request.resource.data.gameId == resource.data.gameId
                    && request.resource.data.gameId == gameId
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.rating is int
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.updatedAt is timestamp;

      // Only the author can delete their rating.
      allow delete: if request.auth != null && userId == request.auth.uid;
    }
  }
}
